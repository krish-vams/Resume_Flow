generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum JobStatus {
  SAVED
  RESUME_NEEDED
  RESUME_GENERATED
  GENERATED
  APPLIED
  RECRUITER_REACHED_OUT
  INTERVIEW
  ASSESSMENT
  REJECTED
  OFFER
  GHOSTED
  WITHDRAWN
}

enum FocusType {
  DOTNET
  AI
  GOLANG
  NODEJS
  JAVA_BACKEND
  CLOUD_DEVOPS
  FULL_STACK
  CUSTOM
}

enum ValidationStatus {
  NOT_RUN
  PASSED
  WARNING
  FAILED
}

enum ReferenceCategory {
  ACTION_VERBS
  ATS_KEYWORDS
  ACCOMPLISHMENT_EXAMPLES
  IMPACT_EXAMPLES
  REWRITING_GUIDE
  OTHER
}

model User {
  id                   String                @id @default(cuid())
  name                 String
  email                String                @unique
  passwordHash         String
  candidateProfiles    CandidateProfile[]
  jobs                 Job[]
  promptTemplates      PromptTemplate[]
  resumeFocusTemplates ResumeFocusTemplate[]
  referenceFiles       ReferenceFile[]
  resumeVersions       ResumeVersion[]
  applications         Application[]
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
}

model CandidateProfile {
  id                 String               @id @default(cuid())
  userId             String
  fullName           String
  email              String
  phone              String?
  location           String?
  linkedinUrl        String?
  githubUrl          String?
  educationJson      Json?
  certificationsJson Json?
  defaultResumeName  String?
  defaultTemplateId  String?
  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  defaultTemplate    ResumeFocusTemplate? @relation(fields: [defaultTemplateId], references: [id])
  resumeVersions     ResumeVersion[]
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@index([userId])
}

model Job {
  id                         String               @id @default(cuid())
  userId                     String
  companyName                String
  jobTitle                   String
  location                   String?
  jobUrl                     String?
  jobType                    String?
  jobDescription             String
  seniorityLevel             String?
  requiredSkillsJson         Json?
  preferredSkillsJson        Json?
  jdKeywordsJson             Json?
  eligibilityFlagsJson       Json?
  focusRecommendationJson    Json?
  recommendedFocusTemplateId String?
  status                     JobStatus            @default(SAVED)
  notes                      String?
  user                       User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  recommendedFocusTemplate   ResumeFocusTemplate? @relation(fields: [recommendedFocusTemplateId], references: [id])
  resumeVersions             ResumeVersion[]
  applications               Application[]
  createdAt                  DateTime             @default(now())
  updatedAt                  DateTime             @updatedAt

  @@index([userId, status])
  @@index([companyName])
}

model PromptTemplate {
  id             String          @id @default(cuid())
  userId         String
  name           String
  description    String?
  promptText     String
  targetRole     String?
  candidateName  String?
  version        Int             @default(1)
  isActive       Boolean         @default(true)
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  resumeVersions ResumeVersion[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([userId, isActive])
}

model ResumeFocusTemplate {
  id                String             @id @default(cuid())
  userId            String
  name              String
  focusType         FocusType
  description       String?
  primaryLanguage   String?
  targetRolesJson   Json?
  baseResumeText    String?
  baseResumeFileUrl String?
  defaultSkillsJson Json?
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  candidateProfiles CandidateProfile[]
  recommendedJobs   Job[]
  resumeVersions    ResumeVersion[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([userId, focusType])
}

model ReferenceFile {
  id           String            @id @default(cuid())
  userId       String
  name         String
  fileType     String
  fileUrl      String
  category     ReferenceCategory
  uploadedAt   DateTime          @default(now())
  parsedStatus String            @default("pending")
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries      ReferenceEntry[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([userId, category])
}

model ReferenceEntry {
  id              String        @id @default(cuid())
  referenceFileId String
  category        String
  title           String?
  content         String
  tagsJson        Json?
  metadataJson    Json?
  referenceFile   ReferenceFile @relation(fields: [referenceFileId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([referenceFileId])
  @@index([category])
}

model ResumeVersion {
  id                 String               @id @default(cuid())
  userId             String
  jobId              String
  candidateProfileId String?
  promptTemplateId   String?
  focusTemplateId    String?
  resumeName         String
  rawResumeText      String?
  rawResumeFileUrl   String?
  formattedDocxUrl   String?
  formattedPdfUrl    String?
  version            Int                  @default(1)
  matchScore         Int?
  validationStatus   ValidationStatus     @default(NOT_RUN)
  status             String               @default("Raw Uploaded")
  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  job                Job                  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidateProfile   CandidateProfile?    @relation(fields: [candidateProfileId], references: [id])
  promptTemplate     PromptTemplate?      @relation(fields: [promptTemplateId], references: [id])
  focusTemplate      ResumeFocusTemplate? @relation(fields: [focusTemplateId], references: [id])
  validation         ResumeValidation?
  applications       Application[]
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@unique([jobId, version])
  @@index([userId, jobId])
}

model ResumeValidation {
  id                         String           @id @default(cuid())
  resumeVersionId            String           @unique
  summaryWordCount           Int?
  accentureBulletCount       Int?
  dreamsBulletCount          Int?
  capitalBulletCount         Int?
  invalidBulletsJson         Json?
  missingRequiredSkillsJson  Json?
  missingPreferredSkillsJson Json?
  languageRuleViolationsJson Json?
  aiToolViolationsJson       Json?
  boldMarkerViolationsJson   Json?
  checksJson                 Json?
  overallScore               Int?
  overallStatus              ValidationStatus @default(NOT_RUN)
  resumeVersion              ResumeVersion    @relation(fields: [resumeVersionId], references: [id], onDelete: Cascade)
  createdAt                  DateTime         @default(now())
}

model Application {
  id              String         @id @default(cuid())
  userId          String
  jobId           String
  resumeVersionId String?
  status          JobStatus      @default(SAVED)
  appliedDate     DateTime?
  followUpDate    DateTime?
  recruiterName   String?
  recruiterEmail  String?
  interviewDate   DateTime?
  notes           String?
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  job             Job            @relation(fields: [jobId], references: [id], onDelete: Cascade)
  resumeVersion   ResumeVersion? @relation(fields: [resumeVersionId], references: [id])
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([userId, status])
  @@index([followUpDate])
}
